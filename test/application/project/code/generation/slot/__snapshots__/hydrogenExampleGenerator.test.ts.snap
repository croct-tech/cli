export async function loader({context}: Route.LoaderArgs) {
  const {content} = await fetchContent('tag-cloud', {scope: context});

  return {content};
}

export default function TagCloudRoute() {
  const {content} = useLoaderData<typeof loader>();

  return (
    <ul>
      <li>
        <strong>Tags</strong>
        <ol>
          {content.tags.map((item, index) => (
            <li key={index}>
              {item}
            </li>
          ))}
        </ol>
      </li>
    </ul>
  );
}
",
      "language": "tsx",
      "path": "app/routes/tag-cloud.tsx",
    },
  ],
}
`;

