  return {content};
}

export default function CtaBlockRoute() {
  const {content} = useLoaderData<typeof loader>();

  return (
    <>
      {content._type === 'button' && (
        <ul>
          <li><strong>Label:</strong> {content.label}</li>
        </ul>
      )}
      {content._type === 'link' && (
        <ul>
          <li><strong>Url:</strong> {content.url}</li>
          <li><strong>Text:</strong> {content.text}</li>
        </ul>
      )}
    </>
  );
}
",
      "language": "tsx",
      "path": "app/routes/cta-block.tsx",
