exports[`PlugNuxtExampleGenerator should generate JavaScript SFCs for booleanWithLabel: booleanWithLabel-js 1`] = `
{
  "files": [
    {
      "code": "<template>
  <FeatureToggle />
</template>",
      "language": "vue",
      "path": "pages/feature-toggle/index.vue",
    },
    {
      "code": "<script setup>
const {data} = await useContent('feature-toggle@1');
</script>

<template>
  <ul v-if="data.content">
    <li><strong>Enabled:</strong> {{ data.content.enabled ? 'Active' : 'Inactive' }}</li>
    <li><strong>Visible:</strong> {{ data.content.visible ? 'Yes' : 'No' }}</li>
  </ul>
</template>",
      "language": "vue",
      "path": "components/feature-toggle.vue",
    },
  ],
}
`;

