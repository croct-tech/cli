exports[`PlugNuxtExampleGenerator should generate JavaScript SFCs for unionInStructure: unionInStructure-js 1`] = `
{
  "files": [
    {
      "code": "<template>
  <Block />
</template>",
      "language": "vue",
      "path": "pages/block/index.vue",
    },
    {
      "code": "<script setup>
const {data} = await useContent('block@1');
</script>

<template>
  <ul v-if="data.content">
    <li>
      <strong>Media</strong>
      <template v-if="data.content.media?._type === 'image'">
        <ul>
          <li><strong>Url:</strong> {{ data.content.media.url }}</li>
        </ul>
      </template>
      <template v-if="data.content.media?._type === 'video'">
        <ul>
          <li><strong>Source:</strong> {{ data.content.media.source }}</li>
        </ul>
      </template>
    </li>
  </ul>
</template>",
      "language": "vue",
      "path": "components/block.vue",
    },
  ],
}
`;

