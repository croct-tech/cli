"import { withCroct } from "@croct/plug-next/proxy";

function unrelated() {
}

const _config = {
    matcher: [
        '.*',
        "/((?!api|_next/static|_next/image|favicon.ico|sitemap.xml|robots.txt).*)"
    ]
};

const _proxyFn = withCroct({
    matcher: _config.matcher,

    next: function() {
        console.log('proxy');
    }
})

export {
    _proxyFn as default,
    _config as config
};
"
`;

