exports[`VuePluginCodemod apply should correctly transform chainedWithStoryblok.ts: chainedWithStoryblok.ts 1`] = `
"import { createCroct } from "@croct/plug-vue";
import { createApp } from 'vue';
import { StoryblokVue, apiPlugin } from '@storyblok/vue';
import App from './App.vue';

createApp(App).use(createCroct({
    appId: "YOUR_APP_ID"
}))
    .use(StoryblokVue, {
        accessToken: 'YOUR_ACCESS_TOKEN',
        use: [apiPlugin],
    })
    .mount('#app');
"
`;

