exports[`VuePluginCodemod apply should correctly transform aliasedFactoryImportAndUsed.ts: aliasedFactoryImportAndUsed.ts 1`] = `
"import { createApp } from 'vue';
import { createCroct as plug } from '@croct/plug-vue';
import App from './App.vue';

